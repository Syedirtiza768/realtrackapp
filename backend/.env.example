PORT=4191

# ── AWS t3.medium (2 vCPU, 4 GB RAM) — local Nest / PM2 on same host ──
NODE_OPTIONS=--max-old-space-size=1536 --dns-result-order=ipv4first --no-network-family-autoselection
DB_POOL_MAX=10
DB_POOL_MIN=2
PIPELINE_AI_CONCURRENCY=3
PIPELINE_AI_BATCH_SIZE=6
PIPELINE_LOCALIZATION_CONCURRENCY=3
PIPELINE_IMAGE_CONCURRENCY=3
PIPELINE_CATEGORY_CONCURRENCY=2
PIPELINE_VIN_BATCH_CONCURRENCY=3
PIPELINE_IMAGE_SKU_CONCURRENCY=2
CATALOG_IMPORT_EBAY_BROWSE_CONCURRENCY=2
CATALOG_IMPORT_IMAGE_SKU_CONCURRENCY=2

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=global321
DB_NAME=listingpro
DB_SYNC=true

LISTINGS_FOLDER_PATH=../files/_same_structure_as_B20_eBay_Verified_2-Oct

# Comma-separated allowed origins (defaults to localhost:5173 + mhn.realtrackapp.com)
# CORS_ORIGIN=https://mhn.realtrackapp.com

# --- eBay multi-store integrations ---
# EBAY_ENV=sandbox
# EBAY_CLIENT_ID=
# EBAY_CLIENT_SECRET=
# EBAY_REDIRECT_URI=http://localhost:4191/api/integrations/ebay/oauth/callback
# EBAY_RU_NAME=
# EBAY_SCOPES=
# EBAY_API_BASE_URL=
# EBAY_OAUTH_BASE_URL=
# Auto-provisioned inventory location when seller has none on eBay:
# EBAY_DEFAULT_MERCHANT_LOCATION_KEY=default
# EBAY_DEFAULT_INVENTORY_ADDRESS_LINE1=Primary Warehouse
# EBAY_DEFAULT_INVENTORY_CITY=Houston
# EBAY_DEFAULT_INVENTORY_STATE=TX
# EBAY_DEFAULT_INVENTORY_POSTAL_CODE=77001
# EBAY_DEFAULT_INVENTORY_COUNTRY=US
# FRONTEND_BASE_URL=http://localhost:3911
# TOKEN_ENCRYPTION_KEY=
# TOKEN_ENCRYPTION_KMS_KEY_ID=
# REDIS_URL=redis://localhost:6379
# EBAY_INTEGRATIONS_REDIS=redis://localhost:6379
# BULLMQ_PREFIX=realtrack
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL_DEFAULT=openai/gpt-4.1-mini
# OPENAI_MODEL_FLAGSHIP=google/gemini-2.5-flash
# OPENAI_MODEL_BULK=deepseek/deepseek-chat-v3-0324
# Single-listing OEM text lookup (/listings/new Fetch details) — benchmark pick: best cost/credibility
# OPENAI_MODEL_TEXT=openai/gpt-4o-mini
# OPENAI_MODEL_ESCALATION=google/gemini-2.5-flash
# OPENAI_CHAT_MODEL=openai/gpt-4.1-mini
# Vision fallback when OEM lookup fails (requires label + overall photos)
# OPENAI_VISION_MODEL=google/gemini-2.5-flash
# OPENAI_LISTING_MODEL=openai/gpt-4.1-mini
# OPENAI_MODEL_FLAGSHIP_MIN_PRICE=200
# AI_LOW_VALUE_MAX_PRICE=50
# OPENAI_VISION_DETAIL=auto
# AI_FITMENT_MIN_ROWS=5
# AI_AUTO_APPROVE_MIN_SCORE=85
# AI_ROUTING_POLICY_PATH=config/ai-routing-policy.json
# AI_OPTIMIZER_ENABLED=false
# AI_OPTIMIZER_CANARY_PERCENT=10
# AI_LEARNING_MIN_SAMPLES=20
# AI_PROMPT_VERSION=enrichment-v2-compact
# AI_TAXONOMY_VALIDATION_ENABLED=false
# AI_RUN_MODE=default
# OPENAI_LISTING_ENRICHMENT_ENABLED=false

# Pipeline output: mirror PicURL images to S3 (default true). Set false to keep original URLs.
# PIPELINE_MIRROR_IMAGES=true

# --- SellerPundit API integration ---
# SELLERPUNDIT_API_BASE_URL=https://authentication.sellerpundit.com/api/v1
# SELLERPUNDIT_MARKETPLACES_URL=https://marketplaces.sellerpundit.com
# SELLERPUNDIT_EMAIL=
# SELLERPUNDIT_PASSWORD=
# SELLERPUNDIT_ENVIRONMENT=production
# SELLERPUNDIT_DEFAULT_MARKETPLACE_ID=EBAY_MOTORS_US
# SELLERPUNDIT_POLICY_SYNC_MAX_AGE_HOURS=24
