DB_NAME=listingpro
DB_SYNC=true

LISTINGS_FOLDER_PATH=../files/_same_structure_as_B20_eBay_Verified_2-Oct

# Comma-separated allowed origins (defaults to localhost:5173 + mhn.realtrackapp.com)
# CORS_ORIGIN=https://mhn.realtrackapp.com

# --- eBay multi-store integrations ---
# EBAY_ENV=sandbox
# EBAY_CLIENT_ID=
# EBAY_CLIENT_SECRET=
# EBAY_REDIRECT_URI=http://localhost:4191/api/integrations/ebay/oauth/callback
# EBAY_RU_NAME=
# EBAY_SCOPES=
# EBAY_API_BASE_URL=
# EBAY_OAUTH_BASE_URL=
# Auto-provisioned inventory location when seller has none on eBay:
# EBAY_DEFAULT_MERCHANT_LOCATION_KEY=default
# EBAY_DEFAULT_INVENTORY_ADDRESS_LINE1=Primary Warehouse
# EBAY_DEFAULT_INVENTORY_CITY=Houston
# EBAY_DEFAULT_INVENTORY_STATE=TX
# EBAY_DEFAULT_INVENTORY_POSTAL_CODE=77001
# EBAY_DEFAULT_INVENTORY_COUNTRY=US
# FRONTEND_BASE_URL=http://localhost:3911
# TOKEN_ENCRYPTION_KEY=
# TOKEN_ENCRYPTION_KMS_KEY_ID=
# REDIS_URL=redis://localhost:6379
# EBAY_INTEGRATIONS_REDIS=redis://localhost:6379
# BULLMQ_PREFIX=realtrack
# OPENAI_API_KEY=
# OPENAI_LISTING_ENRICHMENT_ENABLED=false

# Pipeline output: mirror PicURL images to S3 (default true). Set false to keep original URLs.
# PIPELINE_MIRROR_IMAGES=true
# PIPELINE_IMAGE_SKU_CONCURRENCY=4
# AWS_S3_BUCKET=realtrack-images
# AWS_S3_REGION=us-east-1
# AWS_S3_PREFIX=
# AWS_CLOUDFRONT_DOMAIN=

