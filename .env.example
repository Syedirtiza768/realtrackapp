# ───────────────────────────────────────────────────────────────
# RealTrackApp — Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env
# ───────────────────────────────────────────────────────────────

# ── AWS t3.medium (2 vCPU, 4 GB RAM) — recommended defaults ───
# Budget: ~1.5 GB Node heap + ~512 MB Postgres + ~128 MB Redis + OS headroom.
# Raise NODE_OPTIONS heap only if you upgrade instance RAM (e.g. t3.large).
NODE_OPTIONS=--max-old-space-size=1536 --dns-result-order=ipv4first --no-network-family-autoselection
DB_POOL_MAX=10
DB_POOL_MIN=2
PIPELINE_AI_CONCURRENCY=3
PIPELINE_AI_BATCH_SIZE=6
PIPELINE_LOCALIZATION_CONCURRENCY=3
PIPELINE_IMAGE_CONCURRENCY=3
PIPELINE_CATEGORY_CONCURRENCY=2
PIPELINE_CATEGORY_AI_MODEL=google/gemini-2.5-flash
PIPELINE_VIN_BATCH_CONCURRENCY=3
PIPELINE_IMAGE_SKU_CONCURRENCY=2
CATALOG_IMPORT_EBAY_BROWSE_CONCURRENCY=2
CATALOG_IMPORT_IMAGE_SKU_CONCURRENCY=2

# ── Database (PostgreSQL) ────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=listingpro
DB_PORT_EXTERNAL=5432
DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=true
DB_MIGRATIONS_AT_ENTRYPOINT=true
DB_MIGRATION_HOST=postgres
DB_LOGGING=false

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=
REDIS_PORT_EXTERNAL=6379
# Enable Socket.IO cross-replica rooms when running multiple backend instances
REDIS_SOCKET_ADAPTER=false
# Scheduler leader election (Redis lock) — disable only for single-instance dev
SCHEDULER_LEADER_ENABLED=true

# ── Scale / heavy jobs (Phase 2) ─────────────────────────────
# Max simultaneous pipeline or catalog-import jobs (503 when exceeded)
MAX_CONCURRENT_PIPELINE_JOBS=2
MAX_CONCURRENT_CATALOG_IMPORTS=2
# Slow request logging threshold (ms); logs warn when exceeded
SLOW_REQUEST_MS=2000

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_to_a_random_secret
# Access token lifetime in seconds (default 14400 = 4 hours)
JWT_EXPIRY_SECONDS=14400
# Public self-registration: false in production (default when NODE_ENV=production)
# Set true only for dev/demo installs; admins should use POST /api/rbac/users
ALLOW_PUBLIC_REGISTRATION=false

# ── Demo Users (seed on startup) ─────────────────────────────
# Set SEED_DEMO_USERS=false to skip demo user creation
SEED_DEMO_USERS=true
# Only SUPER_ADMIN_PASSWORD is required; others are optional
DEFAULT_SUPER_ADMIN_EMAIL=admin@realtrack.local
DEFAULT_SUPER_ADMIN_PASSWORD=ChangeMe123!
# DEFAULT_ADMIN_PASSWORD=
# DEFAULT_MANAGER_PASSWORD=
# DEFAULT_STAFF_PASSWORD=
# DEFAULT_VIEWER_PASSWORD=

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:8050,https://mhn.realtrackapp.com,http://mhn.realtrackapp.com

# ── OpenRouter AI ───────────────────────────────────────────
# OpenRouter API key (proxies MiniMax, OpenAI, Anthropic, etc.)
OPENAI_API_KEY=sk-or-v1-...
# OpenRouter base URL (always use this for the OpenAI-compatible SDK)
OPENAI_BASE_URL=https://openrouter.ai/api/v1
# MiniMax M3 — multimodal text+vision model via OpenRouter
OPENAI_CHAT_MODEL=minimax/minimax-m3
OPENAI_VISION_MODEL=minimax/minimax-m3
OPENAI_LISTING_MODEL=minimax/minimax-m3
# Embeddings (not currently used; placeholder for future)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── eBay Developer API ───────────────────────────────────────
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_DEV_ID=
EBAY_ENVIRONMENT=SANDBOX
# Optional legacy override. If set, this takes precedence over EBAY_ENVIRONMENT.
# EBAY_SANDBOX=true
EBAY_REDIRECT_URI=

# ── SellerPundit (optional — import eBay stores via SellerPundit) ──
# Required for Docker: copy these into project root .env (compose does not read backend/.env)
# SELLERPUNDIT_API_BASE_URL=https://authentication.sellerpundit.com/api/v1
# SELLERPUNDIT_MARKETPLACES_URL=https://marketplaces.sellerpundit.com
# SELLERPUNDIT_EMAIL=
# SELLERPUNDIT_PASSWORD=
# SELLERPUNDIT_ENVIRONMENT=production
# SELLERPUNDIT_DEFAULT_MARKETPLACE_ID=EBAY_MOTORS_US
# SELLERPUNDIT_POLICY_SYNC_MAX_AGE_HOURS=24

# ── S3 / Storage ────────────────────────────────────────────
# Example deployment folder: s3://solarrisebackupbucket/mhn/
AWS_S3_BUCKET=solarrisebackupbucket
AWS_S3_PREFIX=mhn/
AWS_S3_REGION=us-east-1
# Legacy aliases (used by docker-compose if set instead of AWS_*)
S3_BUCKET=solarrisebackupbucket
S3_PREFIX=mhn/
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# ── Exposed Ports (optional override) ───────────────────────
FRONTEND_PORT=8050
BACKEND_PORT_EXTERNAL=4191
