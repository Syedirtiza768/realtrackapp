# ───────────────────────────────────────────────────────────────
# RealTrackApp — Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env
# ───────────────────────────────────────────────────────────────

# ── Database (PostgreSQL) ────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=listingpro
DB_PORT_EXTERNAL=5432
DB_SYNCHRONIZE=true
DB_MIGRATIONS_RUN=false
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_LOGGING=false

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=
REDIS_PORT_EXTERNAL=6379

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_to_a_random_secret

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:8050,https://mhn.realtrackapp.com,http://mhn.realtrackapp.com

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── eBay Developer API ───────────────────────────────────────
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_DEV_ID=
EBAY_ENVIRONMENT=SANDBOX
# Optional legacy override. If set, this takes precedence over EBAY_ENVIRONMENT.
# EBAY_SANDBOX=true
EBAY_REDIRECT_URI=

# ── S3 / Storage ────────────────────────────────────────────
# Example deployment folder: s3://solarrisebackupbucket/mhn/
AWS_S3_BUCKET=solarrisebackupbucket
AWS_S3_PREFIX=mhn/
AWS_S3_REGION=us-east-1
# Legacy aliases (used by docker-compose if set instead of AWS_*)
S3_BUCKET=
S3_PREFIX=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Exposed Ports (optional override) ───────────────────────
FRONTEND_PORT=8050
BACKEND_PORT_EXTERNAL=4191
