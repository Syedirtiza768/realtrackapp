# ───────────────────────────────────────────────────────────────
# RealTrackApp — Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env
# ───────────────────────────────────────────────────────────────

# ── Database (PostgreSQL) ────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=listingpro
DB_PORT_EXTERNAL=5432
DB_MIGRATIONS_RUN=true
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_LOGGING=false

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=
REDIS_PORT_EXTERNAL=6379

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_to_a_random_secret

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3911

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── eBay Developer API ───────────────────────────────────────
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_DEV_ID=
EBAY_ENVIRONMENT=SANDBOX
EBAY_REDIRECT_URI=

# ── S3 / Storage ────────────────────────────────────────────
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Exposed Ports (optional override) ───────────────────────
FRONTEND_PORT=3911
BACKEND_PORT_EXTERNAL=4191
